  "license": "MIT",
  "dependencies": {
    "@aura-studio/dynamic-node": "github:aura-studio/dynamic-node",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "uuid": "^10.0.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-lambda": {
      "optional": true
    },
    "@aws-sdk/client-sqs": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
