{
  "name": "@aura-studio/lambda-node",
  "version": "0.1.0",
  "description": "Multi-mode Lambda framework for Node.js (HTTP, ReqResp, SQS, Event)",
  "main": "src/index.js",
  "scripts": {
    "start": "node start.js",
    "test": "node --test test/**/*.test.js",
    "example:http:simple": "node examples/http/simple.js",
    "example:http:config": "node examples/http/config_file.js"
  },
  "keywords": [
    "lambda",
    "aws",
    "serverless",
    "http",
    "sqs",
    "event"
  ],
