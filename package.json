{
  "name": "@aura-studio/lambda-node",
  "version": "0.1.0",
  "description": "Multi-mode Lambda framework for Node.js (HTTP, ReqResp, SQS, Event)",
  "main": "src/index.js",
  "scripts": {
    "start": "node start.js",
    "test": "node --test test/**/*.test.js",
    "example": "node examples/scripts/99-run-all-local.js",
    "example:ui": "node examples/scripts/test-ui.js",
    "example:smoke": "node examples/scripts/01-smoke.js",
    "example:dynamic": "node examples/scripts/02-dynamic.js",
    "example:http:api": "node examples/scripts/03-http-api.js",
    "example:http:wapi": "node examples/scripts/04-http-wapi.js",
    "example:reqresp": "node examples/scripts/05-reqresp.js",
    "example:event": "node examples/scripts/06-event.js",
    "example:sqs": "node examples/scripts/07-sqs.js",
    "example:server": "node examples/scripts/08-server.js",
    "example:clients": "node examples/scripts/09-clients.js"
  },
  "keywords": [
    "lambda",
    "aws",
    "serverless",
    "http",
    "sqs",
    "event"
  ],
  "author": "aura-studio",
  "license": "MIT",
  "dependencies": {
    "@aura-studio/dynamic-node": "github:aura-studio/dynamic-node",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "uuid": "^10.0.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-lambda": {
      "optional": true
    },
    "@aws-sdk/client-sqs": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
